---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { getPosts } from "@/lib/api/posts"
import Pagination from "@/components/shared/Pagination.astro"
import { EmptyState } from "@/components/shared/EmptyState"

export const prerender = false

const pageParam = Number(Astro.url.searchParams.get("page")) || 1
const currentPage = Math.max(1, pageParam)
const limit = 10
const skip = (currentPage - 1) * limit

Astro.response.headers.set("Cache-Control", "public, max-age=300, s-maxage=300")

let posts: import("@/lib/api/posts").Post[] = []
let totalPages = 0
try {
  const result = await getPosts(skip, limit)
  posts = result.posts
  totalPages = Math.ceil(result.total / limit)
} catch {
  posts = []
}

const seo = {
  title: currentPage > 1 ? `Blog - Page ${currentPage} - AstroBP` : "Blog - AstroBP",
  description: "Read the latest articles and tutorials on AstroBP.",
}
---

<BaseLayout {seo}>
  <section class="mx-auto max-w-5xl px-4 py-12">
    <div class="flex items-center justify-between mb-8">
      <h1 class="text-3xl font-bold">Blog</h1>
      <a
        href="/rss.xml"
        title="RSS Feed"
        class="flex items-center gap-1.5 rounded-lg border border-orange-200 bg-orange-50 px-3 py-1.5 text-xs font-medium text-orange-700 hover:bg-orange-100 dark:border-orange-800 dark:bg-orange-950 dark:text-orange-400 dark:hover:bg-orange-900"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M4 11a9 9 0 0 1 9 9" />
          <path d="M4 4a16 16 0 0 1 16 16" />
          <circle cx="5" cy="19" r="1" />
        </svg>
        RSS
      </a>
    </div>
    {posts.length > 0 ? (
      <>
        <div class="grid gap-6 md:grid-cols-2 mb-8">
          {posts.map((post) => (
            <article>
              <a
                href={`/blog/${post.id}`}
                class="rounded-lg border p-6 block hover:bg-accent transition-colors"
              >
                <h2 class="font-semibold text-lg mb-2">{post.title}</h2>
                <p class="text-sm text-muted-foreground line-clamp-2">{post.body}</p>
                <div class="mt-3 flex gap-2">
                  {post.tags.map((tag) => (
                    <span class="text-xs bg-muted px-2 py-0.5 rounded">{tag}</span>
                  ))}
                </div>
              </a>
            </article>
          ))}
        </div>
        {totalPages > 1 && (
          <Pagination currentPage={currentPage} totalPages={totalPages} baseUrl="/blog" />
        )}
      </>
    ) : (
      <EmptyState
        title="No posts yet"
        description="Check back soon for new articles and tutorials."
      />
    )}
  </section>
</BaseLayout>
