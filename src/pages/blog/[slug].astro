---
import BaseLayout from "@/layouts/BaseLayout.astro"
import { getPost } from "@/lib/api/posts"
import {
  Breadcrumb,
  BreadcrumbItem,
  BreadcrumbLink,
  BreadcrumbList,
  BreadcrumbPage,
  BreadcrumbSeparator,
} from "@/components/ui/breadcrumb"
import { ErrorState } from "@/components/shared/ErrorState"

export const prerender = false

const { slug } = Astro.params
const id = Number(slug)
if (!id) return Astro.redirect("/blog")

let post
let error = false
try {
  post = await getPost(id)
} catch {
  error = true
}

const seo = error || !post
  ? { title: "Post Not Found - AstroBP", description: "", noindex: true }
  : {
      title: `${post.title} - AstroBP`,
      description: post.body.slice(0, 160),
      ogType: "article" as const,
      ogImage: `/og.png?title=${encodeURIComponent(post.title)}&description=${encodeURIComponent(post.body.slice(0, 200))}`,
      jsonLd: {
        "@context": "https://schema.org",
        "@type": "Article",
        headline: post.title,
        description: post.body.slice(0, 160),
        author: {
          "@type": "Person",
          name: `User ${post.userId}`,
        },
        keywords: post.tags.join(", "),
        wordCount: post.body.split(" ").length,
      },
    }
---

<BaseLayout seo={seo}>
  {error || !post ? (
    <section class="mx-auto max-w-3xl px-4 py-12">
      <ErrorState
        title="Post not found"
        description="The post you're looking for doesn't exist or has been removed."
      />
    </section>
  ) : (
    <article class="mx-auto max-w-3xl px-4 py-12">
      <div class="mb-6">
        <Breadcrumb>
          <BreadcrumbList>
            <BreadcrumbItem>
              <BreadcrumbLink href="/blog">Blog</BreadcrumbLink>
            </BreadcrumbItem>
            <BreadcrumbSeparator />
            <BreadcrumbItem>
              <BreadcrumbPage>{post.title}</BreadcrumbPage>
            </BreadcrumbItem>
          </BreadcrumbList>
        </Breadcrumb>
      </div>
      <h1 class="text-4xl font-bold mb-4">{post.title}</h1>
      <div class="flex gap-2 mb-6">
        {post.tags.map((tag) => (
          <span class="text-xs bg-muted px-2 py-0.5 rounded">{tag}</span>
        ))}
      </div>
      <p class="text-lg leading-relaxed text-muted-foreground">{post.body}</p>
      <div class="mt-8 flex gap-4 text-sm text-muted-foreground">
        <span>{post.views} views</span>
        <span>{post.reactions.likes} likes</span>
      </div>
    </article>
  )}
</BaseLayout>
